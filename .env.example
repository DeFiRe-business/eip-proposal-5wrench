# ═══════════════════════════════════════════════════════════════════════
#  Sepolia RPC endpoint — required for fork tests AND deployment
# ═══════════════════════════════════════════════════════════════════════
# Get a free RPC URL from:
#   - Alchemy:  https://www.alchemy.com/           (recommended)
#   - Infura:   https://www.infura.io/
#   - QuickNode:https://www.quicknode.com/
#
# Example: https://eth-sepolia.g.alchemy.com/v2/YOUR_API_KEY
SEPOLIA_RPC_URL=

# ═══════════════════════════════════════════════════════════════════════
#  Sepolia Uniswap V3 addresses (defaults provided — verify against docs)
# ═══════════════════════════════════════════════════════════════════════
# Reference: https://docs.uniswap.org/contracts/v3/reference/deployments/ethereum-deployments
SEPOLIA_SWAP_ROUTER_02=0x3bFA4769FB09eefC5a80d6E87c3B9C650f7Ae48E
SEPOLIA_WETH=0xfFf9976782d46CC05630D1f6eBAb18b2324d6B14
SEPOLIA_USDC=0x1c7D4B196Cb0C7B01d743Fbc6116a902379C7238

# ═══════════════════════════════════════════════════════════════════════
#  Deployment (only needed for scripts in script/)
# ═══════════════════════════════════════════════════════════════════════
# Private key of the DEPLOYER wallet. This wallet only pays for the deploy tx
# and has NO authority over the vault after deployment.
# Use a burner wallet funded with a small amount of Sepolia ETH.
# NEVER commit a real private key. NEVER use a key that holds mainnet funds.
#
# Generate a burner: cast wallet new
# Fund it from a Sepolia faucet: https://sepoliafaucet.com/
DEPLOYER_PRIVATE_KEY=

# Address of the vault OWNER (the key that signs spend/execute operations).
# This is the MetaMask EOA that will interact with the vault via the demo frontend.
VAULT_OWNER=

# Initial vault configuration (overridable via env; defaults are sensible)
# Spending limit in wei: 0.05 ETH/epoch
VAULT_SPENDING_LIMIT=50000000000000000
# Epoch duration in seconds: 24 hours
VAULT_EPOCH_DURATION=86400
# Cold vault timelock in seconds: 3 hours (shorter than prod — for demo UX)
VAULT_TIMELOCK_DURATION=10800
# Multisig threshold (must be >= 2 with guardians configured)
VAULT_MULTISIG_THRESHOLD=2

# ═══════════════════════════════════════════════════════════════════════
#  Etherscan API key — for automatic contract verification
# ═══════════════════════════════════════════════════════════════════════
# Get a free key at https://etherscan.io/myapikey
# Required for `forge script ... --verify`
ETHERSCAN_API_KEY=
